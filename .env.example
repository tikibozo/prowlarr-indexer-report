# Copy to .env and fill in. Only PROWLARR_API_KEY is required.
PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=replace-with-your-prowlarr-api-key

# Optional: the Prowlarr URL your *browser* uses, so the report can deep-link to
# it (e.g. http://nas:9696). Leave unset if it's the same as PROWLARR_URL or if
# PROWLARR_URL is a Docker-internal host your browser can't reach. No links shown
# when unset.
# PROWLARR_PUBLIC_URL=http://localhost:9696

# Recent window (days) used for the trend columns + removal heuristic.
WINDOW_DAYS=90

# How often the service re-queries Prowlarr.
REFRESH_INTERVAL_MINUTES=15

# Bind address/port for the web UI.
HOST=0.0.0.0
PORT=8787
